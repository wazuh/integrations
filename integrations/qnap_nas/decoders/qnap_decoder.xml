<decoder name="qnap_qulogd">
  <program_name>^qulogd$</program_name>
</decoder>

<decoder name="qnap_qulogd">
  <parent>qnap_qulogd</parent>
  <regex>Users: (\S+),</regex>
  <order>qnap_user</order>
</decoder>

<decoder name="qnap_qulogd">
  <parent>qnap_qulogd</parent>
  <regex>Source IP: (\d+.\d+.\d+.\d+),</regex>
  <order>srcip</order>
</decoder>

<decoder name="qnap_qulogd">
  <parent>qnap_qulogd</parent>
  <regex>Computer name: (\S+),</regex>
  <order>qnap_hostname</order>
</decoder>

<decoder name="qnap_qulogd">
  <parent>qnap_qulogd</parent>
  <regex>Connection type: (\S+),</regex>
  <order>qnap_conn_type</order>
</decoder>

<decoder name="qnap_qulogd">
  <parent>qnap_qulogd</parent>
  <regex type="pcre2">Accessed resources: ([^,]+),</regex>
  <order>qnap_resource</order>
</decoder>

<decoder name="qnap_qulogd">
  <parent>qnap_qulogd</parent>
  <regex>Action: (\.+)$</regex>
  <order>qnap_action</order>
</decoder>
