<decoder name="endian_custom">
  <program_name>^ulogd</program_name>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex>^(\S+):(\S+):(\d+)</regex>
  <order>endian_chain, endian_action, endian_rule</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex>^(\S+):(\S+)</regex>
  <order>endian_chain, endian_action</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> IN=(\S*) OUT=(\S*) </regex>
  <order>endian_in, endian_out</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> MAC=(\S*) </regex>
  <order>endian_mac</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> SRC=(\S+) DST=(\S+) </regex>
  <order>srcip, dstip</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> TOS=(\S+) </regex>
  <order>endian_tos</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> PREC=(\S+) </regex>
  <order>endian_prec</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> TTL=(\d+) </regex>
  <order>endian_ttl</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> PROTO=(\w+) </regex>
  <order>protocol</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> SPT=(\d+) DPT=(\d+)</regex>
  <order>srcport, dstport</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> LEN=(\d+) </regex>
  <order>endian_len</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> WINDOW=(\d+) </regex>
  <order>endian_window</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> WINDOW=\d+ (\.+) URGP=</regex>
  <order>tcp_flags</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> URGP=(\d+) </regex>
  <order>endian_urgp</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> TYPE=(\d+) CODE=(\d+) </regex>
  <order>icmp_type, icmp_code</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> UID=(\d+) GID=(\d+)</regex>
  <order>endian_uid, endian_gid</order>
</decoder>

<decoder name="endian_custom_child">
  <parent>endian_custom</parent>
  <regex> MARK=(\d+)</regex>
  <order>endian_mark</order>
</decoder>
