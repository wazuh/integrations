<decoder name="endian_icap">
  <program_name>^C-ICAP</program_name>
</decoder>

<decoder name="endian_icap_child">
  <parent>endian_icap</parent>
  <regex>^(\S+)@(\d+.\d+.\d+.\d+) </regex>
  <order>icap_user, srcip</order>
</decoder>

<decoder name="endian_icap_child">
  <parent>endian_icap</parent>
  <regex>^(\d+.\d+.\d+.\d+) (\w+) (\d+)</regex>
  <order>srcip, icap_method, icap_code</order>
</decoder>

<decoder name="endian_icap_child">
  <parent>endian_icap</parent>
  <regex>\w+ \d+ (\S+)\t*\s*[</regex>
  <order>url</order>
</decoder>

<decoder name="endian_icap_child">
  <parent>endian_icap</parent>
  <regex>[MatchedCat: (\.+)]</regex>
  <order>icap_category</order>
</decoder>

<decoder name="endian_icap_child">
  <parent>endian_icap</parent>
  <regex>[Virus: (\.+)]</regex>
  <order>icap_virus</order>
</decoder>

<decoder name="endian_icap_child">
  <parent>endian_icap</parent>
  <regex>[Action: (\.+)]</regex>
  <order>icap_action</order>
</decoder>
