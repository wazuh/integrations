<decoder name="endian_squid">
  <program_name>squid</program_name>
</decoder>

<decoder name="endian_squid_child">
  <parent>endian_squid</parent>
  <regex>^\d+.\d+\t*\s*(\d+) (\S+)</regex>
  <order>squid_duration, srcip</order>
</decoder>

<decoder name="endian_squid_child">
  <parent>endian_squid</parent>
  <regex> (\S+)/(\d+) (\d+) \w+ </regex>
  <order>squid_action, squid_code, squid_bytes</order>
</decoder>

<decoder name="endian_squid_child">
  <parent>endian_squid</parent>
  <regex> \S+/\d+ \d+ (\w+) (\S+) (\S+) </regex>
  <order>squid_method, url, squid_user</order>
</decoder>

<decoder name="endian_squid_child">
  <parent>endian_squid</parent>
  <regex> (\S+)/(\S+) \S+$</regex>
  <order>squid_hierarchy, dstip</order>
</decoder>

<decoder name="endian_squid_child">
  <parent>endian_squid</parent>
  <regex> (\S+)$</regex>
  <order>squid_mime</order>
</decoder>
