<group name="endian_proxy,">

  <rule id="100220" level="2">
    <decoded_as>endian_squid</decoded_as>
    <description>Endian UTM: Web Proxy traffic.</description>
  </rule>

  <rule id="100221" level="3">
    <if_sid>100220</if_sid>
    <field name="squid_code">^2\d\d$|^3\d\d$</field>
    <description>Endian UTM: Proxy allowed $(squid_method) request to $(url).</description>
  </rule>

  <rule id="100222" level="4">
    <if_sid>100221</if_sid>
    <field name="squid_user">\S+</field>
    <description>Endian UTM: User '$(squid_user)' browsed to $(url).</description>
  </rule>

  <rule id="100223" level="5">
    <if_sid>100221</if_sid>
    <field name="squid_bytes">^\d{8,}$</field>
    <description>Endian UTM: Large file download ($(squid_bytes) bytes) from $(url).</description>
    <group>data_exfiltration,</group>
  </rule>


  <rule id="100230" level="2">
    <decoded_as>endian_icap</decoded_as>
    <description>Endian UTM: C-ICAP Filter Event.</description>
  </rule>

  <rule id="100231" level="5">
    <if_sid>100230</if_sid>
    <field name="icap_action">^BLOCKED$</field>
    <field name="icap_category">\.+</field> 
    <description>Endian UTM: Access to $(url) blocked (Category: $(icap_category)).</description>
  </rule>

  <rule id="100232" level="10">
    <if_sid>100230</if_sid>
    <field name="icap_virus">\.+</field> 
    <description>Endian UTM: CRITICAL - Malware download blocked! Virus '$(icap_virus)' detected at $(url).</description>
    <group>malware_detected,virus,</group>
  </rule>

</group>
