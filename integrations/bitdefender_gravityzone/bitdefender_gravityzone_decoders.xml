<decoder name="gravityzone_soc">
  <program_name>CEF</program_name>
  <prematch>\d+\|Bitdefender\|GravityZone\|</prematch>
</decoder>

<decoder name="gravityzone_soc_fields">
  <parent>gravityzone_soc</parent>
  <regex>GravityZone\|(\S+)\|(\d+)\|(\.+)\|(\d+)\|</regex>
  <order>GZVersion,SignatureId,EventName,Severity</order>
</decoder>

<decoder name="gravityzone_soc_fields">
