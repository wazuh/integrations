# ============================================================
# Wazuh Decoder/Rule Tool — Environment Configuration
# ============================================================
# Choose ONE mode below. Comment out the other.

# ── MODE A: Run directly ON the Wazuh server (recommended) ──
# No SSH needed — logtest and file writes happen locally.
WAZUH_REMOTE_ENABLED=false

# If the app doesn't run as root, enable sudo for logtest + file writes:
WAZUH_USE_SUDO=true
# WAZUH_SUDO_PASSWORD=yourpassword    # only if passwordless sudo is NOT configured

# ── MODE B: Run remotely via SSH (app on a different machine) ──
# WAZUH_REMOTE_ENABLED=true
# WAZUH_SSH_HOST=192.168.8.171
# WAZUH_SSH_USER=vagrant
# WAZUH_SSH_PASSWORD=vagrant
# WAZUH_SSH_PORT=22
# WAZUH_SSH_KEY=                      # optional: path to SSH private key

# ── Ollama (local LLM on the Wazuh server) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# ── Optional external LLM fallbacks (leave empty to use Ollama only) ──
# OPENROUTER_API_KEY=
# DASHSCOPE_API_KEY=
