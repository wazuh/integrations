# MCP-LLM Gateway
GATEWAY_API_KEY="secret"
PORT=9912
VERBOSE="true"


# MCP (connects to MCP Server SSE endpoint)
MCP_SSE_URL="http://<mcp-server-IP>:9900/sse"
ALERTS_INDEX="wazuh-alerts-*"
VULN_INDEX="wazuh-states-vulnerabilities-*"
INVENTORY_INDEX="wazuh-states-inventory-*"
DEFAULT_TIME_WINDOW="now-30m"


# Or for Bedrock Claude (default)
#LLM_PROVIDER="claude_bedrock"
#AWS_REGION="us-east-1"
#BEDROCK_MODEL_ID="anthropic.claude-3-sonnet-20240229-v1:0"
#AWS_ACCESS_KEY_ID="<YOUR_ACCESS_KEY_ID>"
#AWS_SECRET_ACCESS_KEY="<YOUR_SECRET_ACCESS_KEY>"


# Or for OpenAI
LLM_PROVIDER="openai"
OPENAI_API_KEY="<key>"
OPENAI_MODEL="gpt-5.2"

# Wazuh API (Manager)
STAGING_WAZUH_API_URL="https://<manager-IP>:55000"
STAGING_WAZUH_API_USER="wazuh-wui"
STAGING_WAZUH_API_PASS="<pass>"
STAGING_WAZUH_API_VERIFY_TLS="false"

GEMINI_API_KEY="<key>"
GEMINI_MODEL="gemini-2.0-flash"

SOC_PROMPT_PATH="/etc/mcp-llm-gateway/mcp-llm-gateway.prompt"

# PROD Wazuh API
WAZUH_API_URL="https://<manager-IP>:55000"
WAZUH_API_USER="wazuh-wui"
WAZUH_API_PASS="<pass>"
WAZUH_API_VERIFY_TLS="false"


# OpenSearch Dashboards (Kibana)
OPENSEARCH_DASHBOARD_URL="https://<dashboard-IP>:443"
OPENSEARCH_DASHBOARD_USER="admin"
OPENSEARCH_DASHBOARD_PASS="<pass>"
OPENSEARCH_DASHBOARD_VERIFY_TLS="false"

# OpenSearch Dashboards (for saved_objects + dashboards)
OSD_URL="https://<dashboard-IP>"          # IMPORTANT: no :5601, use base host
OSD_PORT="443"                      # because node is listening on 443
OSD_USER="admin"
OSD_PASS="<pass>"
OSD_VERIFY_TLS="false"

# Optional (keep default unless you use spaces/basePath)
OSD_SPACE="default"                 
OSD_BASEPATH=""                   

DASHBOARD_PROMPT_PATH="/etc/mcp-llm-gateway/dashboard-builder.prompt"
OPENSEARCH_DASHBOARD_URL="https://<dashboard-IP>:443"
OPENSEARCH_DASHBOARD_VERIFY_TLS="false"

# OpenSearch (for _field_caps)
OPENSEARCH_URL="https://<indexer-ip>:9200"
OPENSEARCH_USER="admin"
OPENSEARCH_PASS="<pass>"
OPENSEARCH_VERIFY_TLS="false"

# ----- Gmail SMTP Configuration -----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="<mail-id>@gmail.com"
SMTP_PASS="<key>"
SMTP_FROM="<mail-id>@gmail.com"
