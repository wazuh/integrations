# ==============================
# Deployment options
# ==============================
DEPLOYMENT_TYPE="all-in-one"

# ==============================
# Wazuh Indexer
# ==============================
WAZUH_INDEXER_IP="127.0.0.1"
WAZUH_INDEXER_PUBLIC_IP="<PUBLIC_IP>"
WAZUH_INDEXER_USER="admin"
WAZUH_INDEXER_PASS="<PASSWORD>"
WAZUH_INDEXER_VERIFY_TLS="false"

# Admin certs for setting root assistant agent
WAZUH_INDEXER_CERT_DIR="/etc/wazuh-indexer/certs"
ADMIN_CERT_FILE="admin.pem"
ADMIN_KEY_FILE="admin-key.pem"
ROOT_CA_FILE="root-ca.pem"

# ==============================
# Wazuh Manager
# ==============================
WAZUH_MANAGER_IP="<MANAGER_IP>"
WAZUH_MANAGER_USER="wazuh"
WAZUH_MANAGER_PASS="<MANAGER_PASSWORD>"
WAZUH_MANAGER_VERIFY_TLS="false"

# ==============================
# Wazuh Dashboard
# ==============================
WAZUH_DASHBOARD_IP="<DASHBOARD_IP>"
WAZUH_DASHBOARD_USER="admin"
WAZUH_DASHBOARD_PASS="<PASSWORD>"
WAZUH_DASHBOARD_VERIFY_TLS="false"

# ==============================
# MCP Server & Gateway
# ==============================
MCP_SERVER_HOST="0.0.0.0"
MCP_SERVER_PORT="9900"
MCP_SERVER_PUBLIC_HOST="<PUBLIC_IP>"
MCP_SSE_URL="http://<PUBLIC_IP>:9900/sse"
GATEWAY_HOST="0.0.0.0"
GATEWAY_PORT="9912"
GATEWAY_PUBLIC_HOST="<PUBLIC_IP>"
GATEWAY_API_KEY="<API_KEY>"

# ==============================
# LLM Provider Configuration
# ==============================
LLM_PROVIDER="openai"

OPENAI_API_KEY="<YOUR_OPENAI_API_KEY>"
OPENAI_MODEL="gpt-4o"

GEMINI_API_KEY="<YOUR_GEMINI_API_KEY>"
GEMINI_MODEL="gemini-2.0-flash"

AWS_REGION="us-east-1"
BEDROCK_MODEL_ID="anthropic.claude-3-sonnet-20240229-v1:0"
AWS_ACCESS_KEY_ID="<YOUR_AWS_ACCESS_KEY_ID>"
AWS_SECRET_ACCESS_KEY="<YOUR_AWS_SECRET_ACCESS_KEY>"

# ==============================
# SMTP
# ==============================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="<SENDER_EMAIL>"
SMTP_PASS="<APP_PASSWORD>"
SMTP_FROM="<SENDER_EMAIL>"
