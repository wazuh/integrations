# ==============================
# Deployment options
# ==============================
INSTALL_SYSTEM_PACKAGES="yes"
INSTALL_MCP_SERVER="yes"
INSTALL_MCP_GATEWAY="yes"
INSTALL_DASHBOARD_PLUGINS="yes"
CONFIGURE_ML_COMMONS="yes"
REGISTER_MODEL_AND_AGENT="yes"
SET_ROOT_AGENT="yes"

# ==============================
# OpenSearch / Wazuh Indexer
# ==============================
WAZUH_INDEXER_IP="<WAZUH_INDEXER_IP>"
OPENSEARCH_URL="https://<WAZUH_INDEXER_IP>:9200"
OPENSEARCH_USER="admin"
OPENSEARCH_PASS="<OPENSEARCH_PASSWORD>"
OPENSEARCH_VERIFY_TLS="false"

# Used by MCP server
OPENSEARCH_USERNAME="admin"
OPENSEARCH_PASSWORD="<OPENSEARCH_PASSWORD>"
OPENSEARCH_SSL_VERIFY="false"

# Admin certs for setting root assistant agent
WAZUH_INDEXER_CERT_DIR="/etc/wazuh-indexer/certs"
ADMIN_CERT_FILE="admin.pem"
ADMIN_KEY_FILE="admin-key.pem"
ROOT_CA_FILE="root-ca.pem"

# ==============================
# MCP Server
# ==============================
MCP_SERVER_HOST="0.0.0.0"
MCP_SERVER_PORT="9900"
MCP_SERVER_PUBLIC_HOST="<PUBLIC_IP>"
MCP_SSE_URL="http://<PUBLIC_IP>:9900/sse"

# ==============================
# MCP-LLM Gateway
# ==============================
GATEWAY_HOST="0.0.0.0"
GATEWAY_PORT="9912"
GATEWAY_PUBLIC_HOST="<PUBLIC_IP>"
GATEWAY_API_KEY="secret"
VERBOSE="true"

ALERTS_INDEX="wazuh-alerts-*"
VULN_INDEX="wazuh-states-vulnerabilities-*"
INVENTORY_INDEX="wazuh-states-inventory-*"
DEFAULT_TIME_WINDOW="now-30m"

# ==============================
# LLM Provider
# Allowed: openai, gemini, claude_bedrock
# ==============================
LLM_PROVIDER="openai"

OPENAI_API_KEY="<OPENAI_API_KEY>"
OPENAI_MODEL="gpt-4"

GEMINI_API_KEY="<GEMINI_API_KEY>"
GEMINI_MODEL="gemini-1.5-pro"

AWS_REGION="us-east-1"
BEDROCK_MODEL_ID="anthropic.claude-3-sonnet-20240229-v1:0"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ==============================
# Wazuh Manager API
# ==============================
WAZUH_API_URL="https://<WAZUH_INDEXER_IP>:55000"
WAZUH_API_USER="wazuh-wui"
WAZUH_API_PASS="<WAZUH_API_PASSWORD>"
WAZUH_API_VERIFY_TLS="false"

STAGING_WAZUH_API_URL="https://<WAZUH_INDEXER_IP>:55000"
STAGING_WAZUH_API_USER="wazuh-wui"
STAGING_WAZUH_API_PASS="<WAZUH_API_PASSWORD>"
STAGING_WAZUH_API_VERIFY_TLS="false"

# ==============================
# Wazuh Dashboard / OpenSearch Dashboards
# ==============================
OPENSEARCH_DASHBOARD_URL="https://<PUBLIC_IP>:443"
OPENSEARCH_DASHBOARD_USER="admin"
OPENSEARCH_DASHBOARD_PASS="<OPENSEARCH_PASSWORD>"
OPENSEARCH_DASHBOARD_VERIFY_TLS="false"

OSD_URL="https://<PUBLIC_IP>"
OSD_PORT="443"
OSD_USER="admin"
OSD_PASS="<OPENSEARCH_PASSWORD>"
OSD_VERIFY_TLS="false"
OSD_SPACE="default"
OSD_BASEPATH=""

# ==============================
# SMTP
# ==============================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="<SENDER_EMAIL>"
SMTP_PASS="<APP_PASSWORD>"
SMTP_FROM="<SENDER_EMAIL>"
