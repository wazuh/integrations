# Sample logs for validating the AlienVault OTX integration end-to-end.
#
# Append these to a Wazuh-monitored log (or pipe them through `wazuh-logtest`)
# to generate alerts containing indicators known to be in OTX pulses. Because
# OTX pulse contents change daily, verify pulse_count > 0 for any indicator
# you rely on:
#
#     curl -s -H "X-OTX-API-KEY: $OTX_KEY" \
#       "https://otx.alienvault.com/api/v1/indicators/IPv4/<IP>/general" \
#       | jq '.pulse_info.count'
#
# Replace the placeholder IPs/domains below with current OTX-known indicators
# pulled from your subscribed pulses:
#
#     curl -s -H "X-OTX-API-KEY: $OTX_KEY" \
#       "https://otx.alienvault.com/api/v1/pulses/subscribed?limit=20" \
#       | jq -r '[.results[] | .indicators[]? | select(.type=="IPv4") | .indicator] | unique | .[0:10][]'

